# Copie para .env na raiz (não commite .env com segredos reais).
# Ver DEPLOY.md e README.md.

NODE_ENV=production
PORT=3000

# PostgreSQL (obrigatório em produção com NODE_ENV=production)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Segredo para assinar JWT — obrigatório em produção ou quando DATABASE_URL está definido
JWT_SECRET=use-a-long-random-string-do-not-use-dev-default

# Origens do front-end permitidas pelo CORS (HTTPS, exatamente como o browser envia).
# Várias origens: separadas por vírgula, sem espaços extras.
# Exemplo monólito na Render: https://ec-routine.onrender.com
# Na Render, se deixar vazio, o servidor também aceita RENDER_EXTERNAL_URL (URL do serviço).
# Exemplo front Hostinger + API Render: https://seudominio.com,https://www.seudominio.com
CORS_ORIGIN=

# Opcional: desativar SSL verificado ao cliente pg (só se o fornecedor exigir)
# PGSSLMODE=disable

# Opcional: número de proxies à frente do Node (Render/Heroku: normalmente 1). Usado por Express trust proxy.
# TRUST_PROXY_HOPS=1

# Painel admin (/admin, GET /api/admin/*): e-mails autorizados, separados por vírgula, em minúsculas.
# Não commite e-mails reais no Git; configure só no painel do host (Render, etc.).
# Exemplo: ADMIN_EMAILS=seuemail@gmail.com
# Se vazio, ninguém tem acesso admin (403).
# ADMIN_EMAILS=
